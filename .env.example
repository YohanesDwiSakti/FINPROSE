# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Auth + Database.
# Dashboard > Project Settings > API.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
# Optional. Leave empty on Vercel so frontend calls the same domain at /api.
VITE_API_BASE_URL=""
# Local API server port (used by server.js and Vite proxy).
API_PORT="5000"
# WhatsApp number opened only after payment succeeds. Use international format,
# for example 6281234567890. If lawyer-specific numbers are added later, they
# can override this fallback number.
VITE_FINPROSE_WHATSAPP_NUMBER="6281234567890"
# Server-side only. Never expose this key in frontend code.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
